From f56e60bfb05121f138f39dec46d7e0b38eb3165a Mon Sep 17 00:00:00 2001
From: Zxilly <zxilly@outlook.com>
Date: Fri, 10 Jul 2026 03:09:33 +0800
Subject: [PATCH] fix(runtime): detect cangjie-built cjc via .cjmetadata
 section

Use the main executable ELF .cjmetadata section as the runtime-local discriminator specified by /tmp/audit/rtcjc_spec.md section 4. Preserve the native C++ cjc exclusion and fail safe to the existing exclusion behavior for unreadable or malformed ELF input.

StackManager.cpp anchors: MainExeIsCangjieBinary() parses /proc/self/exe, and StackManager::InitAddressScope() gates the Linux cjc address scan. Windows and Darwin remain TODO-only; IsRuntimeFrame is unchanged.
---
 runtime/src/StackManager.cpp | 64 ++++++++++++++++++++++++++++++++++--
 1 file changed, 62 insertions(+), 2 deletions(-)

diff --git a/runtime/src/StackManager.cpp b/runtime/src/StackManager.cpp
index fd9ae5b5..5d634583 100644
--- a/runtime/src/StackManager.cpp
+++ b/runtime/src/StackManager.cpp
@@ -6,6 +6,10 @@
 
 
 #include "StackManager.h"
+#if defined(__linux__)
+#include <elf.h>
+#include <link.h>
+#endif
 #include <cstdint>
 
 #include "Base/SysCall.h"
@@ -232,6 +236,58 @@ static void GetSoAddrScope(const CString& str, Uptr& startAddr, Uptr& endAddr)
     endAddr = end > endAddr ? end : endAddr;
 }
 
+#if defined(__linux__)
+// A Cangjie-built executable contains managed frames with stack maps and must not be excluded from stack scanning.
+static bool MainExeIsCangjieBinary()
+{
+    FILE* file = fopen("/proc/self/exe", "rb");
+    if (file == nullptr) {
+        return false;
+    }
+
+    ElfW(Ehdr) elfHeader;
+    if (fread(&elfHeader, 1, sizeof(elfHeader), file) != sizeof(elfHeader) ||
+        memcmp(elfHeader.e_ident, ELFMAG, SELFMAG) != 0 || elfHeader.e_shoff == 0 || elfHeader.e_shnum == 0 ||
+        elfHeader.e_shentsize != sizeof(ElfW(Shdr)) || elfHeader.e_shstrndx >= elfHeader.e_shnum) {
+        fclose(file);
+        return false;
+    }
+
+    size_t sectionHeaderBytes = static_cast<size_t>(elfHeader.e_shnum) * sizeof(ElfW(Shdr));
+    ElfW(Shdr)* sectionHeaders = static_cast<ElfW(Shdr)*>(malloc(sectionHeaderBytes));
+    if (sectionHeaders == nullptr) {
+        fclose(file);
+        return false;
+    }
+    if (fseek(file, static_cast<long>(elfHeader.e_shoff), SEEK_SET) != 0 ||
+        fread(sectionHeaders, sizeof(ElfW(Shdr)), elfHeader.e_shnum, file) != elfHeader.e_shnum) {
+        free(sectionHeaders);
+        fclose(file);
+        return false;
+    }
+
+    ElfW(Shdr) stringTableHeader = sectionHeaders[elfHeader.e_shstrndx];
+    char* stringTable = static_cast<char*>(malloc(stringTableHeader.sh_size));
+    bool found = false;
+    if (stringTable != nullptr && fseek(file, static_cast<long>(stringTableHeader.sh_offset), SEEK_SET) == 0 &&
+        fread(stringTable, 1, stringTableHeader.sh_size, file) == stringTableHeader.sh_size) {
+        constexpr char cangjieMetadataSection[] = ".cjmetadata";
+        for (uint16_t i = 0; i < elfHeader.e_shnum; ++i) {
+            size_t nameOffset = sectionHeaders[i].sh_name;
+            if (nameOffset < stringTableHeader.sh_size &&
+                stringTableHeader.sh_size - nameOffset >= sizeof(cangjieMetadataSection) &&
+                memcmp(&stringTable[nameOffset], cangjieMetadataSection, sizeof(cangjieMetadataSection)) == 0) {
+                found = true;
+                break;
+            }
+        }
+    }
+    free(stringTable);
+    free(sectionHeaders);
+    fclose(file);
+    return found;
+}
+#endif
 
 static void GetEachSoAddrScope(std::vector<CString>& soNameVec)
 {
@@ -348,11 +404,15 @@ void StackManager::InitAddressScope()
 
 // Init cjc address info.
 #if defined(__linux__) // Linux, ANDROID, OHOS
-    std::vector<CString> cjcSoNameVec = { "cjc\n" };
-    GetEachSoAddrScope(cjcSoNameVec);
+    if (!MainExeIsCangjieBinary()) {
+        std::vector<CString> cjcSoNameVec = { "cjc\n" };
+        GetEachSoAddrScope(cjcSoNameVec);
+    }
 #elif defined(_WIN64)                         // Windows
+    // TODO: Gate this exclusion by the Cangjie PE section when self-hosted cjc is enabled on Windows.
     InitAddressInfoOnWindows("cjc.exe", StackManager::cjcSoStartAddr, StackManager::cjcSoEndAddr);
 #elif defined(__APPLE__) && !defined(__IOS__) // MacOS
+    // TODO: Gate this exclusion by the Cangjie Mach-O section when self-hosted cjc is enabled on Darwin.
     InitAddressInfoOnDarwin("/cjc", StackManager::cjcSoStartAddr, StackManager::cjcSoEndAddr);
 #endif
 }
