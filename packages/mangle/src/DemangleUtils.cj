package cangjie_compiler::mangle

// Mirrors demangler/Utils.h:MANGLE_STDPKG_MAP.
func MANGLE_STDPKG_MAP(pkg: String): Option<String> {
    return match (pkg) {
        case "ab" => "std.sync"
        case "ac" => "std.collection"
        case "ad" => "std.deriving"
        case "ae" => "std.database"
        case "af" => "std.net"
        case "ag" => "std.chirad"
        case "ah" => "std.io"
        case "ai" => "std.convert"
        case "aj" => "std.ffi"
        case "ak" => "std.argopt"
        case "al" => "std.objectpool"
        case "am" => "std.reflect"
        case "an" => "std.fs"
        case "ao" => "std.runtime"
        case "ap" => "std.overflow"
        case "aq" => "std.unittest"
        case "ar" => "std.binary"
        case "as" => "std.unicode"
        case "at" => "std.core"
        case "au" => "std.console"
        case "av" => "std.random"
        case "aw" => "std.sort"
        case "ax" => "std.ast"
        case "ay" => "std.env"
        case "ba" => "std.process"
        case "bb" => "std.time"
        case "bc" => "std.regex"
        case "bd" => "std.posix"
        case "be" => "std.crypto"
        case "bf" => "std.ref"
        case "bg" => "std.math"
        case "bh" => "std.collection.concurrent"
        case "bi" => "std.collection.concurrent.native"
        case "bj" => "std.deriving.impl"
        case "bk" => "std.deriving.builtins"
        case "bl" => "std.deriving.api"
        case "bm" => "std.deriving.resolve"
        case "bn" => "std.database.sql"
        case "bo" => "std.net.native"
        case "bq" => "std.convert.native"
        case "bs" => "std.objectpool.native"
        case "bt" => "std.fs.native"
        case "bu" => "std.runtime.native"
        case "bv" => "std.unittest.mock"
        case "bw" => "std.unittest.testmacro"
        case "bx" => "std.unittest.prop_test"
        case "by" => "std.unittest.common"
        case "ca" => "std.unittest.native"
        case "cb" => "std.unittest.diff"
        case "cc" => "std.unittest.mock.mockmacro"
        case "cd" => "std.unittest.mock.internal"
        case "ce" => "std.core.native"
        case "cf" => "std.random.native"
        case "cg" => "std.ast.native"
        case "ch" => "std.env.native"
        case "ci" => "std.process.native"
        case "cj" => "std.time.native"
        case "ck" => "std.regex.native"
        case "cl" => "std.posix.native"
        case "cm" => "std.crypto.digest"
        case "cn" => "std.crypto.cipher"
        case "co" => "std.math.numeric"
        case "cp" => "std.math.native"
        case "cq" => "std.math.numeric.native"
        case _ => None
    }
}
