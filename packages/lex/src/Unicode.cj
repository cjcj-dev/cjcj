private func containsUnicodeRange(ranges: Array<(UInt32, UInt32)>, codepoint: UInt32): Bool {
    var low: Int64 = 0
    var high: Int64 = ranges.size - 1
    while (low <= high) {
        let mid = low + ((high - low) / 2)
        let range = ranges[mid]
        if (codepoint < range[0]) {
            high = mid - 1
        } else if (codepoint > range[1]) {
            low = mid + 1
        } else {
            return true
        }
    }
    return false
}

private func isXIDStart(codepoint: UInt32): Bool {
    return containsUnicodeRange(XID_START_RANGES, codepoint)
}

func isCJXIDStart(value: Int64): Bool {
    if (value < 0) {
        return false
    }
    if (value == Int64(b'_')) {
        return true
    }
    return isXIDStart(UInt32(value))
}

func isXIDContinue(value: Int64): Bool {
    if (value < 0) {
        return false
    }
    let codepoint = UInt32(value)
    return isXIDStart(codepoint) || containsUnicodeRange(XID_CONTINUE_EXTRA_RANGES, codepoint)
}
