public let ANSI_NO_COLOR: String = ""
public let ANSI_COLOR_RESET: String = "\u{1b}[0m"
public let ANSI_COLOR_BRIGHT: String = "\u{1b}[1m"
public let ANSI_COLOR_BLACK: String = "\u{1b}[30m"
public let ANSI_COLOR_RED: String = "\u{1b}[31m"
public let ANSI_COLOR_GREEN: String = "\u{1b}[32m"
public let ANSI_COLOR_YELLOW: String = "\u{1b}[33m"
public let ANSI_COLOR_BLUE: String = "\u{1b}[34m"
public let ANSI_COLOR_MAGENTA: String = "\u{1b}[35m"
public let ANSI_COLOR_CYAN: String = "\u{1b}[36m"
public let ANSI_COLOR_WHITE: String = "\u{1b}[37m"
public let ANSI_COLOR_WHITE_BACKGROUND_BLACK_FOREGROUND: String = "\u{1b}[30;47m"
